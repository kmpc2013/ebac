        <mxCell id="Tzc-8lZmMvzsrZfGIFRI-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;verticalAlign=top;fontStyle=1" value="&lt;div style=&quot;text-align: start;&quot;&gt;&lt;span style=&quot;background-color: transparent; font-size: 13px; font-weight: 400; text-wrap-mode: nowrap;&quot;&gt;&lt;font color=&quot;#cccccc&quot; face=&quot;Segoe WPC, Segoe UI, sans-serif&quot;&gt;✅&lt;/font&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;Código confiável&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="130" x="1090" y="660" as="geometry" />
        </mxCell>
        <mxCell id="Tzc-8lZmMvzsrZfGIFRI-37" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="160" width="700" x="480" y="200" as="geometry" />
        </mxCell>
        <mxCell id="Tzc-8lZmMvzsrZfGIFRI-35" parent="Tzc-8lZmMvzsrZfGIFRI-37" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;" value="&lt;span style=&quot;font-weight: 700; text-align: start; white-space: nowrap;&quot;&gt;✅ Benefícios do TDD&lt;/span&gt;" vertex="1">
          <mxGeometry height="160" width="700.0000000000001" as="geometry" />
        </mxCell>
        <mxCell id="Tzc-8lZmMvzsrZfGIFRI-36" parent="Tzc-8lZmMvzsrZfGIFRI-37" style="rounded=0;whiteSpace=wrap;html=1;strokeColor=none;" value="&lt;ol style=&quot;text-align: left;&quot;&gt;&lt;li&gt;🔒 Maior confiabilidade: O código é validado continuamente por uma suite de testes&lt;/li&gt;&lt;li&gt;🐛 Redução de bugs: Erros são capturados no momento em que são introduzidos&lt;/li&gt;&lt;li&gt;🧼 Design mais limpo: A escrita do teste força um acoplamento menor e interfaces mais claras&lt;/li&gt;&lt;li&gt;⚡ Feedback rápido: Falhas são detectadas em segundos, não dias&lt;/li&gt;&lt;li&gt;📖 Documentação viva: Os testes documentam o comportamento esperado do sistema&lt;/li&gt;&lt;li&gt;🛡️ Refatoração segura: Você pode melhorar o código com a confiança de que os testes validam o comportamento&lt;/li&gt;&lt;/ol&gt;" vertex="1">
          <mxGeometry height="104.6153846153846" width="673.0769230769232" x="13.461538461538463" y="43.07692307692307" as="geometry" />
        </mxCell>
        <mxCell id="Tzc-8lZmMvzsrZfGIFRI-38" parent="1" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=center;" value="&lt;div&gt;&lt;b&gt;🧭 O que é TDD?&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;TDD (Desenvolvimento Orientado a Testes) é uma prática de desenvolvimento onde os &lt;b&gt;testes são escritos antes do código&lt;/b&gt; de produção. O ciclo curto e repetitivo &quot;Red → Green → Refactor&quot; guia o design do software, garantindo que cada funcionalidade seja validada desde o início.&lt;b&gt;&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="160" width="380" x="80" y="200" as="geometry" />
        </mxCell>
        <mxCell id="Tzc-8lZmMvzsrZfGIFRI-39" parent="1" style="rounded=1;whiteSpace=wrap;html=1;" value="Testes não devem depender uns dos outros nem de estado global" vertex="1">
          <mxGeometry height="60" width="120" x="510" y="1030" as="geometry" />
        </mxCell>
        <mxCell id="Tzc-8lZmMvzsrZfGIFRI-46" connectable="0" parent="1" style="group" value="" vertex="1">
          <mxGeometry height="360" width="300" x="650" y="760" as="geometry" />
