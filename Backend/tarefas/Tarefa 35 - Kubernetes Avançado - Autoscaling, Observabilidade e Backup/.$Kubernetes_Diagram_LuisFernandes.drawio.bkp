        <mxCell id="help_resilience" value="&lt;b&gt;Resiliência&lt;/b&gt;&lt;br&gt;Mantém a aplicação disponível mesmo em caso de falhas." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#ffd54f;fontSize=13;align=left;verticalAlign=middle;spacing=10;arcSize=10;" vertex="1" parent="help">
          <mxGeometry x="25" y="215" width="395" height="65" as="geometry" />
