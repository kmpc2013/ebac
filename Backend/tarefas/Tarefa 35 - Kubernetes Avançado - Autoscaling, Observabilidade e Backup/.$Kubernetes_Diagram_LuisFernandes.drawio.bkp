          <mxGeometry x="255" y="44" width="610" height="28" as="geometry" />
        </mxCell>
        <mxCell id="service" value="&lt;b&gt;Service&lt;/b&gt;&lt;br&gt;Define a política de acesso e expõe os pods." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=center;verticalAlign=middle;arcSize=12;spacing=8;shadow=0;" vertex="1" parent="cluster">
          <mxGeometry x="70" y="225" width="210" height="100" as="geometry" />
