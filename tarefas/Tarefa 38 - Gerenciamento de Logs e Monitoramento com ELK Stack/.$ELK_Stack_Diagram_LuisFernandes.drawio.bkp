        <mxCell id="right_card3" parent="right_panel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#fb7185;fontSize=13;align=left;verticalAlign=middle;spacing=12;arcSize=12;shadow=0;" value="&lt;b&gt;Manutenção contínua&lt;/b&gt;&lt;br&gt;Facilita dashboards, alertas e melhorias incrementais." vertex="1">
          <mxGeometry height="170" width="330" x="25" y="475" as="geometry" />
