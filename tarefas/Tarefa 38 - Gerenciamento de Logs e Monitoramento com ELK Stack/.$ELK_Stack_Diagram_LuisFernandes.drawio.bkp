        <mxCell id="right_panel" parent="1" style="swimlane;startSize=34;rounded=1;arcSize=8;whiteSpace=wrap;html=1;fillColor=#fff1f2;strokeColor=#fb7185;fontSize=16;fontStyle=1;shadow=0;fontColor=#9f1239;" value="Benefícios do monitoramento" vertex="1">
          <mxGeometry height="760" width="380" x="1390" y="170" as="geometry" />
        </mxCell>
        <mxCell id="right_note" parent="right_panel" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#374151;" value="A leitura fica mais direta quando os ganhos operacionais aparecem ao lado do fluxo principal." vertex="1">
          <mxGeometry height="36" width="330" x="25" y="48" as="geometry" />
