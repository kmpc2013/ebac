        <mxCell id="right_card2" parent="right_panel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#22c55e;fontSize=13;align=left;verticalAlign=middle;spacing=12;arcSize=12;shadow=0;" value="&lt;b&gt;Análise de performance&lt;/b&gt;&lt;br&gt;Mostra picos de latência, gargalos e padrões de uso." vertex="1">
