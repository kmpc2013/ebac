        <mxCell id="right_footer" parent="right_panel" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=12;fontColor=#9f1239;" value="Monitorar logs ajuda a manter qualidade, disponibilidade e previsibilidade." vertex="1">
