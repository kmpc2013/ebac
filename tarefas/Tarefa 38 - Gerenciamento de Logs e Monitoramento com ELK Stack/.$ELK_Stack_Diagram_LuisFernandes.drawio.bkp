        <mxCell id="right_card1" parent="right_panel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#f59e0b;fontSize=13;align=left;verticalAlign=middle;spacing=12;arcSize=12;shadow=0;" value="&lt;b&gt;Tempo real&lt;/b&gt;&lt;br&gt;Detecta incidentes cedo e reduz o tempo de resposta." vertex="1">
